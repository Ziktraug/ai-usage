{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.json",
      "!**/.output",
      "!**/.turbo",
      "!**/dist",
      "!apps/web/src/routeTree.gen.ts",
      "!**/node_modules",
      "!**/styled-system"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": [
                  "../packages/**",
                  "../../packages/**",
                  "../../../packages/**",
                  "../apps/**",
                  "../../apps/**",
                  "../../../apps/**",
                  "@ai-usage/*/src",
                  "@ai-usage/*/src/**"
                ],
                "message": "Use workspace package imports and public package exports instead of relative workspace paths or private src paths."
              }
            ]
          }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "overrides": [
    {
      "includes": ["packages/lan-pairing/src/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@ai-usage/*",
                      "../packages/**",
                      "../../packages/**",
                      "../../../packages/**",
                      "../apps/**",
                      "../../apps/**",
                      "../../../apps/**",
                      "@ai-usage/*/src",
                      "@ai-usage/*/src/**"
                    ],
                    "message": "packages/lan-pairing must stay project-agnostic and cannot import ai-usage domain packages."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["packages/report-core/src/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@ai-usage/*",
                      "../packages/**",
                      "../../packages/**",
                      "../../../packages/**",
                      "../apps/**",
                      "../../apps/**",
                      "../../../apps/**",
                      "@ai-usage/*/src",
                      "@ai-usage/*/src/**"
                    ],
                    "message": "packages/report-core is pure domain code and cannot import workspace runtime packages."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
