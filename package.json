{
  "name": "ai-usage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "ai-usage": "./apps/cli/src/main.ts"
  },
  "scripts": {
    "start": "turbo run start --filter=@ai-usage/cli --",
    "quota": "turbo run quota --filter=@ai-usage/cli",
    "dev:report": "turbo run dev --filter=@ai-usage/report",
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "^1.2.0",
    "turbo": "^2.6.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {}
}
