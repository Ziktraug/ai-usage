{
  "name": "ai-usage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "ai-usage": "./apps/cli/src/main.ts"
  },
  "scripts": {
    "cli": "bun apps/cli/src/main.ts",
    "dev": "bun run --cwd apps/report dev",
    "html": "bun apps/cli/src/html.ts",
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "dependencies": {}
}
