{
  "name": "@ai-usage/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@ai-usage/design-system": "workspace:*",
    "@ai-usage/local-collectors": "workspace:*",
    "@ai-usage/report-core": "workspace:*",
    "@ai-usage/report-data": "workspace:*",
    "@ai-usage/skills": "workspace:*",
    "@ai-usage/usage-merge": "workspace:*",
    "@ai-usage/usage-store": "workspace:*",
    "@tanstack/solid-query": "^5.101.2",
    "@tanstack/solid-router": "1.170.16",
    "@tanstack/solid-start": "1.168.26",
    "@tanstack/solid-table": "^8.21.3",
    "effect": "^3.21.4",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.11.3",
    "@playwright/test": "1.61.1",
    "nitro": "^3.0.260610-beta",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12"
  },
  "scripts": {
    "dev": "bun --bun vite --host 127.0.0.1",
    "dev:prepare": "CI=1 panda codegen --silent && CI=1 panda cssgen --silent",
    "dev:standalone": "bun --filter @ai-usage/design-system build && bun run dev:prepare && bun run dev",
    "build": "bun --filter @ai-usage/design-system build && CI=1 panda codegen --silent && CI=1 panda cssgen --silent && tsc --noEmit && rm -rf dist .output && vite build",
    "check": "bun --filter @ai-usage/design-system build && CI=1 panda codegen --silent && CI=1 panda cssgen --silent && tsc --noEmit",
    "test": "bun --filter @ai-usage/design-system build && bun test src",
    "test:e2e": "playwright test",
    "test:e2e-production": "playwright test --config playwright.production.config.ts e2e/production-report.spec.ts",
    "preview": "vite preview --host 127.0.0.1",
    "start": "bun start.mjs",
    "lint": "biome check .",
    "format": "biome format --write ."
  }
}
